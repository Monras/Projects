{
  "title": "System Sensors",
  "uid": "system-sensors",
  "schemaVersion": 38,
  "version": 3,
  "refresh": "5s",
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "panels": [
    {
      "id": 1,
      "title": "CPU Core Temperatures",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "min": 20,
          "max": 110,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "orange", "value": 85 },
              { "color": "red", "value": 95 }
            ]
          },
          "custom": { "lineWidth": 2 }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "label_replace(label_replace(label_replace(node_hwmon_temp_celsius{chip=\"platform_coretemp_0\"},\"sensor_name\",\"CPU Package\",\"sensor\",\"temp1\"),\"sensor_name\",\"Core 0\",\"sensor\",\"temp2\"),\"sensor_name\",\"Core 1\",\"sensor\",\"temp3\")",
          "legendFormat": "{{sensor_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "CPU Frequency per Core",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "hertz",
          "custom": { "lineWidth": 1 }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "node_cpu_scaling_frequency_hertz",
          "legendFormat": "Core {{cpu}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Fan Speeds",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "rotrpm",
          "min": 0,
          "custom": { "lineWidth": 2 }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "node_hwmon_fan_rpm{sensor!='fan2'}",
          "legendFormat": "{{chip}} {{sensor}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Battery Charge",
      "type": "gauge",
      "gridPos": { "x": 12, "y": 8, "w": 6, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 20 },
              { "color": "yellow", "value": 40 },
              { "color": "green", "value": 60 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "node_power_supply_capacity{power_supply=~\"BAT.*\"}",
          "legendFormat": "{{power_supply}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Battery Status",
      "type": "stat",
      "gridPos": { "x": 18, "y": 8, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          { "matcher": { "id": "byName", "options": "Charging" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] },
          { "matcher": { "id": "byName", "options": "Discharging" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }] },
          { "matcher": { "id": "byName", "options": "Full" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }] }
        ]
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "name",
        "colorMode": "background"
      },
      "targets": [
        {
          "expr": "node_power_supply_info{power_supply=~\"BAT.*\"}",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Battery Power Draw",
      "type": "timeseries",
      "gridPos": { "x": 18, "y": 12, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "custom": { "lineWidth": 2 }
        }
      },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "hidden" }
      },
      "targets": [
        {
          "expr": "node_power_supply_power_watt{power_supply=~\"BAT.*\"}",
          "legendFormat": "Power",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "GPU Temperature (hwmon / AMD)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "min": 20,
          "max": 110,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "orange", "value": 85 },
              { "color": "red", "value": 95 }
            ]
          },
          "custom": { "lineWidth": 2 }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "node_hwmon_temp_celsius{chip=~\".*amdgpu.*|.*radeon.*\"}",
          "legendFormat": "{{chip}} {{sensor}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "title": "GPU Temperature (NVIDIA)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "min": 20,
          "max": 110,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "orange", "value": 85 },
              { "color": "red", "value": 95 }
            ]
          },
          "custom": { "lineWidth": 2 }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "nvidia_smi_temperature_gpu",
          "legendFormat": "GPU {{gpu}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "title": "Thermal Zones",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 24, "w": 24, "h": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "custom": { "lineWidth": 1 }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "node_thermal_zone_temp",
          "legendFormat": "{{zone}} ({{type}})",
          "refId": "A"
        }
      ]
    }
  ]
}
